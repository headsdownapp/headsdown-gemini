{
  "name": "headsdown",
  "version": "0.3.0",
  "description": "Availability awareness and task gating for Gemini CLI.",
  "settings": [
    {
      "name": "HEADSDOWN_TOKEN",
      "description": "API Token for HeadsDown (managed via headsdown_auth)",
      "type": "string"
    }
  ],
  "skills": [
    "./skills/headsdown"
  ],
  "agents": [
    "./agents/headsdown.md"
  ],
  "hooks": [
    {
      "event": "SessionStart",
      "command": "node ${extensionPath}/dist/hooks/session-start.js"
    },
    {
      "event": "BeforeAgent",
      "command": "node ${extensionPath}/dist/hooks/before-agent.js"
    },
    {
      "event": "BeforeTool",
      "command": "node ${extensionPath}/dist/hooks/check-availability.js"
    }
  ],
  "mcpServers": {
    "headsdown": {
      "command": "node",
      "args": [
        "${extensionPath}/dist/index.js"
      ]
    }
  }
}
