{
  "name": "headsdown",
  "version": "0.4.0",
  "description": "Availability awareness and task gating for Gemini CLI.",
  "settings": [
    {
      "name": "HEADSDOWN_TOKEN",
      "description": "API Token for HeadsDown (managed via headsdown_auth)",
      "type": "string"
    }
  ],
  "skills": [
    "./skills/headsdown"
  ],
  "agents": [
    "./agents/headsdown.md"
  ],
  "commands": [
    "./commands"
  ],
  "hooks": [
    {
      "event": "SessionStart",
      "command": "node ${extensionPath}/dist/hooks/session-start.js"
    },
    {
      "event": "BeforeAgent",
      "command": "node ${extensionPath}/dist/hooks/before-agent.js"
    },
    {
      "event": "BeforeTool",
      "command": "node ${extensionPath}/dist/hooks/check-availability.js"
    }
  ],
  "mcpServers": {
    "headsdown": {
      "command": "node",
      "args": [
        "${extensionPath}/dist/index.js"
      ]
    }
  },
  "themes": [
    {
      "name": "HeadsDown Focus",
      "type": "custom",
      "colors": {
        "background.primary": "#1a0f0f",
        "border.accent": "#ff4d4d",
        "text.accent": "#ff6666",
        "text.primary": "#ffffff"
      }
    },
    {
      "name": "HeadsDown Flow",
      "type": "custom",
      "colors": {
        "background.primary": "#0f1a1a",
        "border.accent": "#4dffb8",
        "text.accent": "#66ffcc",
        "text.primary": "#ffffff"
      }
    }
  ]
}
